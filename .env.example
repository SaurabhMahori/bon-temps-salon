# Bon Temps Salon — Environment Variables
# Copy this file to .env and fill in values as needed.

# No required environment variables for local development.
# The app runs entirely on the frontend.

# Optional: Analytics, CMS, or email service integrations
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key
